# BookKeepr AI - Environment Configuration
# Copy to .env and fill in your values

# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=your-super-secret-key-here-change-in-production

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/bookkeepr

# QuickBooks OAuth (Intuit Developer Portal)
# https://developer.intuit.com/
INTUIT_CLIENT_ID=your-intuit-client-id
INTUIT_CLIENT_SECRET=your-intuit-client-secret
INTUIT_SANDBOX_MODE=true
INTUIT_REDIRECT_URI=http://localhost:5000/auth/callback

# OAuth Scopes (space-separated)
INTUIT_SCOPES=openid profile email com.intuit.quickbooks.accounting

# Redis (for Celery - Future Phase)
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO

# Application
APP_NAME=BookKeepr AI
APP_URL=http://localhost:5000
