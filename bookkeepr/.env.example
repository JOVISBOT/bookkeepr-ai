# ==========================================
# BookKeepr AI - Environment Configuration
# Copy to .env and fill in your values.
# NEVER commit .env to git.
# ==========================================

# Flask
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=false
SECRET_KEY=change-this-to-a-random-64-char-hex-string

# Database
# SQLite for local dev (auto-created):
DATABASE_URL=sqlite:///instance/bookkeepr.db
# PostgreSQL for production (Render provides this automatically):
# DATABASE_URL=postgresql://user:pass@host:5432/bookkeepr

# Token encryption — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# QuickBooks / Intuit — https://developer.intuit.com/
INTUIT_CLIENT_ID=
INTUIT_CLIENT_SECRET=
INTUIT_REDIRECT_URI=http://localhost:5000/quickbooks/callback
INTUIT_ENVIRONMENT=sandbox
# Set to 'production' when going live with real clients
INTUIT_SCOPES=openid profile email com.intuit.quickbooks.accounting

# Stripe — https://dashboard.stripe.com/apikeys
# Leave blank for demo mode (no real charges)
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs — set after creating products in Stripe dashboard
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_BUSINESS_MONTHLY=

# Email — https://sendgrid.com (free: 100 emails/day)
# Leave blank to use console-log fallback in development
SENDGRID_API_KEY=
MAIL_FROM=noreply@bookkeepr.ai

# Anthropic Claude AI — https://console.anthropic.com
# Optional — local classifier works without it
ANTHROPIC_API_KEY=

# Redis — for rate limiting persistence in production
# Leave blank to use in-memory (fine for single dyno)
REDIS_URL=redis://localhost:6379/0

# Application
APP_NAME=BookKeepr AI
APP_URL=http://localhost:5000
# Set to your live URL in production:
# APP_URL=https://your-app.onrender.com

# Logging
LOG_LEVEL=INFO
