# ==========================================
# BookKeepr AI - Environment Configuration
# ==========================================

# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-string-in-production

# Database
DATABASE_URL=postgresql://bookkeepr_user:password@localhost:5432/bookkeepr_dev
# For SQLite (dev only): sqlite:///bookkeepr.db

# QuickBooks / Intuit API
# Get these from: https://developer.intuit.com/
INTUIT_CLIENT_ID=your_quickbooks_client_id_here
INTUIT_CLIENT_SECRET=your_quickbooks_client_secret_here
INTUIT_REDIRECT_URI=http://localhost:5000/auth/qbo/callback
INTUIT_ENVIRONMENT=sandbox
# Options: sandbox, production
# Use 'sandbox' for development, 'production' for live

# OpenAI (for AI categorization)
OPENAI_API_KEY=sk-your_openai_key_here

# Stripe (for billing)
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Intuit QuickBooks Webhooks
# Get these from Intuit Developer Portal: https://developer.intuit.com/
INTUIT_WEBHOOK_SECRET=your_intuit_webhook_secret_here
INTUIT_WEBHOOK_TOKEN=your_intuit_webhook_verifier_token_here  # Optional

# Redis (for Celery task queue)
REDIS_URL=redis://localhost:6379/0

# Email Configuration (for notifications)
# Options: smtp, sendgrid, mailgun
EMAIL_PROVIDER=smtp
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Application Settings
APP_NAME=BookKeepr AI
APP_URL=http://localhost:5000
SUPPORT_EMAIL=support@bookkeepr.ai

# Feature Flags
ENABLE_QBD=false
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_EMAIL_NOTIFICATIONS=true

# Logging
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR
